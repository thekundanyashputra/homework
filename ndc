Question 11: Nginx Reverse Proxy
VM1 & VM2:

bash
sudo apt install apache2 -y
echo "<h1>Exam Portal</h1>" | sudo tee /var/www/html/index.html
sudo systemctl restart apache2
VM3:

bash
sudo apt install nginx -y
sudo nano /etc/nginx/nginx.conf
nginx.conf:

nginx
http {
    upstream exam_server {
        server 192.168.1.51:80;
    }
    upstream result_server {
        server 192.168.1.52:80;
    }
    server {
        listen 80;
        location /exam {
            proxy_pass http://exam_server/;
        }
        location /result {
            proxy_pass http://result_server/;
        }
    }
}
